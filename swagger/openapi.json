"],"summary":"Listar roles disponibles","description":"Requiere Token de EMPRESA o SUPERVISOR. Sirve como diccionario para rellenar desplegables en el Frontend.","operationId":"obtenerRoles","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"type":"string","enum":["EMPLEADO","SUPERVISOR"]}}}}}}}},"/api/empleados/me":{"get":{"tags":["3. Empleados"],"summary":"Obtener mi perfil (Empleado)","description":"Requiere Token de EMPLEADO o SUPERVISOR. Devuelve la información personal y contractual del empleado autenticado.","operationId":"obtenerMiPerfil_1","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/RespuestaEmpleadoDTO"}}}}}}},"/api/ausencias/tipos":{"get":{"tags":["7. Ausencias"],"summary":"Listar tipos de ausencia","description":"Requiere Token de EMPRESA, SUPERVISOR o EMPLEADO. Diccionario para formularios (ej: VACACIONES, BAJA_MEDICA).","operationId":"obtenerTiposAusencia","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"type":"string","enum":["MEDICA","VACACIONES","MOTIVO_PERSONAL","OTROS"]}}}}}}}},"/api/ausencias/me":{"get":{"tags":["7. Ausencias"],"summary":"Mis solicitudes de ausencia","description":"Requiere Token de EMPLEADO (o SUPERVISOR). Recupera el historial de ausencias solicitadas por el usuario autenticado, filtrable por estado.","operationId":"obtenerMisAusencias","parameters":[{"name":"estado","in":"query","required":false,"schema":{"type":"string","enum":["SOLICITADA","APROBADA","RECHAZADA"]}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/RespuestaAusenciaDTO"}}}}}}}},"/api/ausencias/justificantes/{nombreArchivo}":{"get":{"tags":["7. Ausencias"],"summary":"Descargar justificante","description":"Requiere Token de EMPRESA, SUPERVISOR o EMPLEADO. Descarga el archivo físico del justificante asociado a una ausencia.","operationId":"descargarJustifican